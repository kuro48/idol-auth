{
  "$id": "https://idol-auth.local/schemas/identity.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Identity",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "primary_identifier_type": {
          "type": "string",
          "enum": ["email", "phone"],
          "title": "Primary Identifier Type"
        },
        "email": {
          "type": "string",
          "format": "email",
          "title": "Email",
          "ory.sh/kratos": {
            "credentials": {
              "password": {
                "identifier": true
              },
              "code": {
                "identifier": true,
                "via": "email"
              }
            },
            "recovery": {
              "via": "email"
            },
            "verification": {
              "via": "email"
            }
          }
        },
        "phone": {
          "type": "string",
          "title": "Phone Number",
          "ory.sh/kratos": {
            "credentials": {
              "password": {
                "identifier": true
              }
            }
          }
        },
        "display_name": {
          "type": "string",
          "title": "Display Name",
          "maxLength": 50
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
