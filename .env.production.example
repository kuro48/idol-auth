# Copy this file to .env.production and fill in every value
# Never commit .env.production to version control

# ── Hostnames ─────────────────────────────────────────────────────────────────

# アプリ API を公開するドメイン（例: auth.yourdomain.com）
APP_BASE_URL=
APP_HOSTNAME=

# Kratos self-service UI（ポータル）を公開するドメイン（例: accounts.yourdomain.com）
PORTAL_APP_URL=
PORTAL_HOSTNAME=

# Hydra public エンドポイントを公開するドメイン（例: login.yourdomain.com）
HYDRA_HOSTNAME=

# Let's Encrypt ACME 登録に使うメールアドレス
ACME_EMAIL=

# ── Datastore ─────────────────────────────────────────────────────────────────

# PostgreSQL のパスワード。本番では長いランダム文字列を使うこと
# 例: openssl rand -hex 32
POSTGRES_PASSWORD=

# アプリが PostgreSQL に接続する DSN（postgres コンテナへの内部 URL）
# Docker Compose 内部ネットワーク経由のため sslmode=disable でも盗聴リスクは低いが、
# 本番では sslmode=require または sslmode=verify-full を推奨する。
# ※ config.go の Validate() は本番環境で sslmode=disable を明示的に拒否する。
DATABASE_URL=postgres://idol:${POSTGRES_PASSWORD}@postgres:5432/idol_auth?sslmode=require

# Redis のパスワード。本番では長いランダム文字列を使うこと
REDIS_PASSWORD=

# Kratos が PostgreSQL に接続する DSN（kratos スキーマ）
KRATOS_DSN=postgres://idol:${POSTGRES_PASSWORD}@postgres:5432/idol_auth?sslmode=require&search_path=kratos

# Hydra が PostgreSQL に接続する DSN（hydra スキーマ）
HYDRA_DSN=postgres://idol:${POSTGRES_PASSWORD}@postgres:5432/idol_auth?sslmode=require&search_path=hydra

# ── Internal service URLs（コンテナ間通信。変更不要）────────────────────────────

KRATOS_PUBLIC_URL=http://kratos:4433
KRATOS_ADMIN_URL=http://kratos:4434
HYDRA_PUBLIC_URL=http://hydra:4444
HYDRA_ADMIN_URL=http://hydra:4445

# ── Browser-facing Ory URLs ───────────────────────────────────────────────────

# ブラウザが Kratos に直接アクセスするときの URL（= PORTAL_APP_URL と同じドメイン）
KRATOS_BROWSER_URL=

# ブラウザが Hydra に直接アクセスするときの URL（= HYDRA_HOSTNAME と同じドメイン）
HYDRA_BROWSER_URL=

# セッションクッキーのドメイン（サブドメインをまたぐ場合は親ドメインを指定）
SESSION_COOKIE_DOMAIN=

# ── Admin ─────────────────────────────────────────────────────────────────────

# 管理 API の初回認証トークン。長いランダム文字列を使い、通常運用後は無効化する
# 例: openssl rand -hex 32
ADMIN_BOOTSTRAP_TOKEN=

# 管理者として認可するメールアドレス（カンマ区切り）
ADMIN_ALLOWED_EMAILS=

# 管理者として認可するロール名（カンマ区切り）
ADMIN_ALLOWED_ROLES=

# adminctl が接続する管理 API の公開 URL
ADMIN_API_BASE_URL=

# ── Security / network ────────────────────────────────────────────────────────

# セッションクッキーを HTTPS のみに制限する（本番は常に true）
SESSION_COOKIE_SECURE=true

# リバースプロキシの IP レンジ（X-Forwarded-For を信頼する範囲。Caddy/VPS 内部なら変更不要）
TRUSTED_PROXIES=10.0.0.0/8,192.168.0.0/16

# ── Logging ───────────────────────────────────────────────────────────────────

# アプリのログレベル（debug / info / warn / error）
LOG_LEVEL=info
APP_LOG_LEVEL=info

# Ory コンテナのログレベル
ORY_LOG_LEVEL=info

# ── Kratos ────────────────────────────────────────────────────────────────────

# TOTP 二要素認証の発行者名（認証アプリに表示される）
KRATOS_TOTP_ISSUER=

# メール送信元アドレス
KRATOS_SMTP_FROM_ADDRESS=

# メール送信者表示名
KRATOS_SMTP_FROM_NAME=

# SMTP 接続 URI（例: smtps://user:pass@smtp.example.com:465）
KRATOS_SMTP_CONNECTION_URI=

# Kratos の署名・クッキー・暗号化に使うシークレット（それぞれ独立したランダム文字列）
# 例: openssl rand -hex 32
KRATOS_SECRETS_DEFAULT=
KRATOS_SECRETS_COOKIE=
KRATOS_SECRETS_CIPHER=

# ── Hydra ─────────────────────────────────────────────────────────────────────

# Hydra のシステムシークレット（32 文字以上のランダム文字列）
# 例: openssl rand -hex 32
HYDRA_SYSTEM_SECRET=

# ブラウザクライアントが直接 Hydra を呼ぶ場合のみ true にする（通常は false）
HYDRA_PUBLIC_CORS_ENABLED=false

# CORS を許可するオリジン（HYDRA_PUBLIC_CORS_ENABLED=true の場合のみ設定）
CORS_ALLOWED_ORIGINS=
