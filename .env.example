# Copy this file to .env and fill in the values
# Never commit .env to version control

# ── Datastore ────────────────────────────────────────────────────────────────

# PostgreSQL のパスワード。ローカル開発用なので任意の文字列でよい
POSTGRES_PASSWORD=

# Redis のパスワード。ローカル開発用なので任意の文字列でよい
REDIS_PASSWORD=

# ── Secrets ───────────────────────────────────────────────────────────────────

# Hydra がトークン署名・暗号化に使うシステムシークレット。32 文字以上のランダム文字列
# 例: openssl rand -hex 32
HYDRA_SYSTEM_SECRET=

# ── Admin ────────────────────────────────────────────────────────────────────

# 管理 API の初回認証に使うブートストラップトークン。任意のランダム文字列
# 本番では長いランダム値に置き換え、通常運用後は無効化する
ADMIN_BOOTSTRAP_TOKEN=

# 管理者として認可するメールアドレス（カンマ区切り）
ADMIN_ALLOWED_EMAILS=

# 管理者として認可するロール名（カンマ区切り）
ADMIN_ALLOWED_ROLES=

# 管理 API のベース URL（adminctl が接続先として使う）
ADMIN_API_BASE_URL=http://localhost:8080

# ── Browser-facing URLs ───────────────────────────────────────────────────────

# ブラウザが Kratos に直接アクセスするときの URL（ログイン・登録・MFA フロー用）
# Docker 外のブラウザから届くので localhost を使う
KRATOS_BROWSER_URL=http://localhost:4433

# ブラウザが Hydra に直接アクセスするときの URL（OAuth2 認可フロー用）
HYDRA_BROWSER_URL=http://localhost:4444

# ── Demo client ───────────────────────────────────────────────────────────────

# デモクライアントアプリのブラウザ向け URL（OIDC redirect_uri に登録される）
DEMO_APP_URL=http://localhost:3002

# デモクライアントのリスニングポート
DEMO_PORT=3002

# デモコンテナ内部から Kratos へのアクセス URL（Docker ネットワーク内部名を使う）
DEMO_KRATOS_PUBLIC_URL=http://kratos:4433

# デモコンテナ内部から Kratos admin API へのアクセス URL
DEMO_KRATOS_ADMIN_URL=http://kratos:4434

# デモコンテナ内部から Hydra へのアクセス URL（Docker ネットワーク内部名を使う）
DEMO_HYDRA_PUBLIC_URL=http://hydra:4444

# ── CORS ──────────────────────────────────────────────────────────────────────

# CORS で許可するオリジン（カンマ区切り）。ブラウザクライアントが直接 API を叩く場合のみ設定
CORS_ALLOWED_ORIGINS=http://localhost:3002

# ── Demo OAuth client metadata ───────────────────────────────────────────────

# デモ用 OAuth クライアントの表示名（同意画面などに出る）
DEMO_PARTNER_APP_NAME=

# デモ用 OAuth クライアントの識別子スラッグ（英小文字・ハイフン）
DEMO_PARTNER_APP_SLUG=

# デモ用 OAuth クライアントの説明文
DEMO_PARTNER_APP_DESCRIPTION=
